generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Caixa {
  id           String   @id @default(uuid())
  data         String
  faturamento  Float
  lucro        Float
  despesas     Float
}
model Metas {
  id_meta String @id @default(uuid())
  createdAt DateTime @default(now())
  name String
  description String
  dataCaixa String
  type String
  progress Float
}
model Campanhas {
  id_campanha String @id @default(uuid())
  dateInit DateTime
  dateFinish DateTime
  name String
  canal String
  value_inv Float
  cpi Float
  cpv Float
  interessados Int
  vendas Int
}
model Atividades {
  id_atividade String @id @default(uuid())
  name String
  category String
  data_prazo String
  status String
  progress Float
  period String
}