generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Caixa {
  id           String   @id @default(uuid())
  data         String
  faturamento  Float
  lucro        Float
  despesas     Float
}
model Metas {
  id_meta String @id @default(uuid())
  createdAt DateTime @default(now())
  name String
  description String
  dataCaixa String
  type String
  progress Float
}